{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker Mutation Testing Configuration - Target: 95% mutation score",
  "packageManager": "npm",
  "reporters": [
    "progress",
    "clear-text",
    "html",
    "json"
  ],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!src/tests/**/*",
    "!src/main.ts",
    "!src/telemetry.ts",
    "!src/logger.ts",
    "!src/config/swagger.ts",
    "!src/prisma/prisma-client.ts",
    "!src/prisma/seed.ts",
    "!dist/**/*",
    "!node_modules/**/*"
  ],
  "tempDirName": ".stryker-temp",
  "cleanTempDir": true,
  "timeoutMS": 60000,
  "concurrency": 4,
  "tsconfigFile": "tsconfig.json",
  "logLevel": "info",
  
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts"
  },
  
  "thresholds": {
    "high": 95,
    "low": 90,
    "break": 85
  },
  
  "plugins": [
    "@stryker-mutator/jest-runner"
  ],
  
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".stryker-temp",
    "coverage"
  ]
}