{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/ts",
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "types": ["node"]
  },
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/tests/**/*",
  ],
  "include": [
    "src/**/*.ts"
  ]
}
